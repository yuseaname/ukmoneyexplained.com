# Hostinger Cloud Startup — Deployment Configuration
# Copy this file to .env and fill in your details.

# Public domain used after deployment
SITE_DOMAIN=ukmoneyexplained.com

# SSH connection details for Hostinger hPanel
# DEPLOY_HOST: find in hPanel > Hosting Plan > SSH Access (e.g. ukmoneyexplained.com or server IP)
# DEPLOY_USER: your hPanel username (e.g. u123456789)
# DEPLOY_PATH: /home/YOUR_HPANEL_USERNAME/public_html
# DEPLOY_PORT: 65002 (Hostinger always uses this port for hPanel hosting)
DEPLOY_HOST=ukmoneyexplained.com
DEPLOY_USER=your-hpanel-username
DEPLOY_PATH=/home/your-hpanel-username/public_html
DEPLOY_PORT=65002
