# Hostinger Cloud Startup — Deployment Configuration
# Copy this file to .env and fill in your details.

# Public domain used after deployment
SITE_DOMAIN=ukmoneyexplained.com

# SSH connection details for Hostinger
DEPLOY_HOST=your-server-ip-or-hostname
DEPLOY_USER=your-ssh-username
DEPLOY_PATH=/var/www/ukmoneyexplained.com/current
DEPLOY_PORT=22
